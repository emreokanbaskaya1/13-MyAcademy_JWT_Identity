@{
    ViewData["Title"] = "Home";
}

<div class="sr">
    <!-- Hero -->
    <div class="page-hero page-container">
        <div class="media bg-media">
            <div class="media-content" style="background-image:url(/bepop/assets/img/b2.jpg)"></div>
        </div>
        <div class="p-5 pos-rlt text-center">
            <h1 class="display-3 font-weight-bold text-white mb-5 mx-5">Music platform for artists and music lovers.</h1>
            <a asp-controller="Home" asp-action="Discover" class="btn btn-md gd-primary text-white m-2">Discover new Music</a>
            <a asp-controller="Home" asp-action="SignUp" class="btn btn-md btn-outline-light m-2">Register Free</a>
        </div>
    </div>

    <!-- Artists CTA -->
    <div class="page-container p-5 pos-rlt">
        <div class="py-5 text-center">
            <h2 class="display-4 font-weight-bold text-white mb-5">Artists on Bepop</h2>
            <p>Find the most popular artists and listen to their music on Bepop.</p>
            <div class="py-4">
                <a asp-controller="Home" asp-action="Artists" class="btn btn-md btn-outline-primary m-2">Explore artists</a>
                <a asp-controller="Home" asp-action="Packages" class="btn btn-md btn-outline-primary m-2">View Packages</a>
            </div>
        </div>
    </div>

