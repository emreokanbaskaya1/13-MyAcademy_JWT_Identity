@{
    ViewData["Title"] = "History";
}

<div class="page-content page-container" id="page-content">
    <div class="padding sr">
        <div class="page-hero">
            <div class="media bg-media">
                <div class="media-content" style="background-image:url(/bepop/assets/img/b3.jpg)"></div>
            </div>
            <div class="pos-rlt">
                <h2 class="display-3 font-weight-bold text-white">Listening History</h2>
                <div class="col-6 px-0 py-3 text-muted">
                    <p>Dinlediğin şarkıların kaydını burada görebilirsin.</p>
                </div>
            </div>
        </div>

        <div class="heading pt-5 pb-3 d-flex">
            <div>
                <div class="text-muted sr-item">Your</div>
                <h5 class="text-highlight sr-item">Recently Played</h5>
            </div>
            <span class="flex"></span>
        </div>

        <div id="historyContainer" class="row list-row list-index">
            <div class="col-12 text-center text-muted py-5">
                <i data-feather="music" style="width:48px;height:48px;"></i>
                <p class="mt-3">No listening history yet. Start playing music!</p>
            </div>
        </div>
    </div>
</div>
