@{
    ViewData["Title"] = "÷neriler";
}

@section Styles {
<style>
    .rec-badge {
        display: inline-flex; align-items: center; gap: 6px;
        font-size: 0.72rem; font-weight: 600; padding: 4px 10px;
        border-radius: 20px; margin-bottom: 16px;
    }
    .rec-badge.ml   { background: rgba(99,102,241,0.15); color: #818cf8; }
    .rec-badge.pop  { background: rgba(251,191,36,0.15); color: #fbbf24; }

    .rec-grid .list-item { transition: transform .2s, box-shadow .2s; }
    .rec-grid .list-item:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(0,0,0,0.3); }

    .rec-info-card {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 14px;
        padding: 24px;
        margin-bottom: 24px;
    }
    .rec-info-card h6 { font-size: 0.78rem; color: #9ca3af; text-transform: uppercase; letter-spacing: .07em; margin-bottom: 10px; }

    .skel {
        background: linear-gradient(90deg,
            rgba(255,255,255,0.04) 25%,
            rgba(255,255,255,0.09) 50%,
            rgba(255,255,255,0.04) 75%);
        background-size: 200% 100%;
        animation: shim 1.4s infinite;
        border-radius: 6px;
    }
    @@keyframes shim {
        0%   { background-position: 200% 0; }
        100% { background-position: -200% 0; }
    }

    .empty-state { text-align:center; padding:60px 20px; color:#4b5563; }

    .train-btn {
        background: rgba(99,102,241,0.15);
        border: 1px solid rgba(99,102,241,0.35);
        color: #818cf8;
        border-radius: 20px;
        font-size: 0.75rem;
        padding: 6px 16px;
        cursor: pointer;
        transition: all .2s;
    }
    .train-btn:hover { background: rgba(99,102,241,0.3); color: #fff; }
    .train-btn:disabled { opacity: 0.5; cursor: not-allowed; }
</style>
}

<div class="page-content page-container" id="page-content">
    <div class="padding">

        <!-- BaĢlżk -->
        <div class="heading pt-4 pb-2 d-flex align-items-center">
            <div>
                <h4 class="text-highlight">Sana ÷zel ÷neriler</h4>
                <p class="text-muted" style="font-size:0.85rem;">ML.NET ile dinleme alżĢkanlżklarżna gŲre Ģarkż Ųnerileri.</p>
            </div>
            <span class="flex"></span>
            <button class="train-btn" id="trainBtn" title="Modeli yeniden eūit">
                <i data-feather="refresh-cw" style="width:13px;height:13px;" class="mr-1"></i>
                Modeli Eūit
            </button>
        </div>

        <!-- GiriĢ yok -->
        <div id="notLoggedIn" class="empty-state" style="display:none;">
            <svg xmlns="http://www.w3.org/2000/svg" width="52" height="52" fill="none" viewBox="0 0 24 24"
                 stroke="currentColor" stroke-width="1.2" style="opacity:.35;">
                <circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
            </svg>
            <p style="font-size:1rem;color:#6b7280;margin:12px 0;">÷nerileri gŲrmek iÁin giriĢ yap.</p>
            <a asp-controller="Home" asp-action="SignIn"
               class="btn btn-rounded gd-primary text-white mt-2">GiriĢ Yap</a>
        </div>

        <!-- Ana iÁerik -->
        <div id="recContent" style="display:none;">

            <!-- Model durumu badge -->
            <div id="modelBadge"></div>

            <!-- Skeleton -->
            <div id="skeleton" class="row row-md" style="display:none;">
                @for (int i = 0; i < 6; i++)
                {
                    <div class="col-4 col-md-3 col-lg-2 col-xl-1-8 mb-3">
                        <div style="border-radius:10px;overflow:hidden;">
                            <div class="skel" style="padding-top:100%;"></div>
                            <div style="padding:10px;">
                                <div class="skel" style="height:13px;width:70%;margin-bottom:6px;"></div>
                                <div class="skel" style="height:11px;width:50%;"></div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- řarkż listesi -->
            <div id="recList" class="row row-md rec-grid"></div>

            <!-- BoĢ durum -->
            <div id="emptyState" class="empty-state" style="display:none;">
                <svg xmlns="http://www.w3.org/2000/svg" width="56" height="56" fill="none" viewBox="0 0 24 24"
                     stroke="currentColor" stroke-width="1.2" style="opacity:.35;">
                    <path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/>
                </svg>
                <p style="font-size:1rem;color:#6b7280;margin:12px 0 4px;">HenŁz Ųneri oluĢturulamadż.</p>
                <p style="font-size:0.82rem;color:#4b5563;">Daha fazla Ģarkż dinleyerek Ųnerilerin kalitesini artżrabilirsin!</p>
                <a asp-controller="Home" asp-action="Discover"
                   class="btn btn-rounded gd-primary text-white mt-3">KeĢfet</a>
            </div>

        </div><!-- /recContent -->

    </div>
</div>

@section Scripts {
<script>
(function () {
    'use strict';

    function esc(v) {
        return String(v || '')
            .replace(/&/g,'&amp;').replace(/</g,'&lt;')
            .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    function initRecommendationsPage() {
        var token     = localStorage.getItem('jwtToken');
        var notLogged = document.getElementById('notLoggedIn');
        var content   = document.getElementById('recContent');
        var skeleton  = document.getElementById('skeleton');
        var recList   = document.getElementById('recList');
        var emptyEl   = document.getElementById('emptyState');
        var badgeEl   = document.getElementById('modelBadge');
        var trainBtn  = document.getElementById('trainBtn');

        if (!recList) return;

        function show(el) { if (el) el.style.display = ''; }
        function hide(el) { if (el) el.style.display = 'none'; }

        hide(notLogged); hide(content); hide(skeleton); hide(emptyEl);
        recList.innerHTML = '';
        if (badgeEl) badgeEl.innerHTML = '';

        if (!token) {
            show(notLogged);
            hide(trainBtn);
            if (typeof feather !== 'undefined') feather.replace();
            return;
        }

        show(content);
        show(skeleton);

        function fetchRecommendations() {
            hide(emptyEl);
            hide(recList);
            show(skeleton);
            recList.innerHTML = '';

            fetch('/api/recommendations?count=12', {
                headers: { 'Authorization': 'Bearer ' + token }
            })
            .then(function (res) {
                if (res.status === 401) {
                    localStorage.removeItem('jwtToken');
                    hide(content); hide(skeleton);
                    show(notLogged);
                    return null;
                }
                if (!res.ok) { hide(skeleton); show(emptyEl); return null; }
                return res.json();
            })
            .then(function (data) {
                if (!data) return;
                hide(skeleton);

                // Model durumu badge
                if (badgeEl) {
                    if (data.isModelTrained) {
                        badgeEl.innerHTML = '<span class="rec-badge ml"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg> ML Model Aktif ó KiĢiselleĢtirilmiĢ ÷neriler</span>';
                    } else {
                        badgeEl.innerHTML = '<span class="rec-badge pop"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg> Model henŁz eūitilmedi ó PopŁler řarkżlar gŲsteriliyor</span>';
                    }
                }

                var songs = data.songs || [];
                if (songs.length === 0) {
                    show(emptyEl);
                    if (typeof feather !== 'undefined') feather.replace();
                    return;
                }

                var html = '';
                songs.forEach(function (s) {
                    var cover = esc(s.artistImageUrl || s.coverImageUrl || '/bepop/assets/img/c0.jpg');
                    var locked = !s.isAccessible;
                    var pkgBadge = locked
                        ? '<span style="position:absolute;top:8px;right:8px;background:rgba(0,0,0,0.7);color:#fbbf24;font-size:0.65rem;padding:2px 8px;border-radius:10px;z-index:5;">' + esc(s.packageName) + '</span>'
                        : '';

                    html +=
                        '<div class="col-4 col-md-3 col-lg-2 col-xl-1-8 mb-3">' +
                          '<div class="list-item r list-hover" style="position:relative;">' +
                            pkgBadge +
                            '<div class="media">' +
                              '<a class="media-content" style="background-image:url(' + cover + ')"' +
                                ' onerror="this.style.backgroundImage=\'url(/bepop/assets/img/c0.jpg)\'"></a>' +
                              '<div class="media-action media-action-overlay">' +
                                '<button class="btn btn-icon no-bg no-shadow hide-row" data-toggle-class>' +
                                  '<i data-feather="heart" class="active-fill"></i>' +
                                '</button>' +
                                '<button class="btn btn-raised btn-icon btn-rounded bg--white btn-play"' +
                                  ' onclick="playSong(' + s.id + ')" title="' + esc(s.title) + ' Áal"></button>' +
                              '</div>' +
                            '</div>' +
                            '<div class="list-content text-center">' +
                              '<div class="list-body">' +
                                '<span class="list-title title h-1x">' + esc(s.title) + '</span>' +
                                '<span class="list-subtitle d-block text-muted h-1x subtitle">' + esc(s.artistName) + '</span>' +
                              '</div>' +
                            '</div>' +
                          '</div>' +
                        '</div>';
                });

                recList.innerHTML = html;
                show(recList);
                if (typeof feather !== 'undefined') feather.replace({ width: 16, height: 16 });
            })
            .catch(function (err) {
                console.error('Recommendations fetch error:', err);
                hide(skeleton);
                show(emptyEl);
            });
        }

        fetchRecommendations();

        // Model yeniden eūitme butonu
        if (trainBtn) {
            trainBtn.onclick = function () {
                trainBtn.disabled = true;
                trainBtn.innerHTML = '<i data-feather="loader" style="width:13px;height:13px;" class="mr-1"></i> Eūitiliyor...';
                if (typeof feather !== 'undefined') feather.replace({ width: 13, height: 13 });

                fetch('/api/recommendations/train', {
                    method: 'POST',
                    headers: { 'Authorization': 'Bearer ' + token }
                })
                .then(function (res) { return res.json(); })
                .then(function (data) {
                    trainBtn.disabled = false;
                    trainBtn.innerHTML = '<i data-feather="refresh-cw" style="width:13px;height:13px;" class="mr-1"></i> Modeli Eūit';
                    if (typeof feather !== 'undefined') feather.replace({ width: 13, height: 13 });

                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'success',
                            title: 'Model Eūitildi!',
                            text: data.isModelTrained
                                ? 'ML model baĢarżyla gŁncellendi. ÷neriler yenileniyor...'
                                : 'Yeterli veri yok, popŁler Ģarkżlar gŲsterilecek.',
                            timer: 2000,
                            showConfirmButton: false,
                            background: '#1a1a2e',
                            color: '#e0e0e0'
                        });
                    }

                    // ÷nerileri yeniden yŁkle
                    fetchRecommendations();
                })
                .catch(function () {
                    trainBtn.disabled = false;
                    trainBtn.innerHTML = '<i data-feather="refresh-cw" style="width:13px;height:13px;" class="mr-1"></i> Modeli Eūit';
                    if (typeof feather !== 'undefined') feather.replace({ width: 13, height: 13 });
                });
            };
        }
    }

    initRecommendationsPage();
    window._pageInitRan = true;
    window.pageInit = initRecommendationsPage;
})();
</script>
}
