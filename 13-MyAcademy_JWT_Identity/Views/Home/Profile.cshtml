@{
    ViewData["Title"] = "Profilim";
}

@section Styles {
<style>
    .package-badge {
        display: inline-block;
        padding: 0.35rem 0.9rem;
        border-radius: 2rem;
        font-size: 0.8rem;
        font-weight: 600;
        letter-spacing: 0.5px;
    }
    .package-1 { background: linear-gradient(135deg,#f5af19,#f12711); color:#fff; }
    .package-2 { background: linear-gradient(135deg,#a18cd1,#fbc2eb); color:#fff; }
    .package-3 { background: linear-gradient(135deg,#f7971e,#ffd200); color:#1a1b22; }
    .package-4 { background: linear-gradient(135deg,#56ccf2,#2f80ed); color:#fff; }
    .package-5 { background: linear-gradient(135deg,#9b9b9b,#cfcfcf); color:#1a1b22; }
    .package-6 { background: rgba(255,255,255,0.1); color:#aaa; border:1px solid rgba(255,255,255,0.2); }

    .profile-card {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 12px;
        padding: 2rem;
        margin-bottom: 1.5rem;
    }
    .profile-card > .card-label {
        font-size: 0.68rem;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: #6c7781;
        margin-bottom: 1.25rem;
        display: block;
    }
    .form-control-dark {
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.12);
        color: #fff;
        border-radius: 8px;
    }
    .form-control-dark:focus {
        background: rgba(255,255,255,0.09);
        border-color: #c02afe;
        color: #fff;
        box-shadow: 0 0 0 2px rgba(192,42,254,0.25);
    }
    .form-control-dark::placeholder { color: #6c7781; }

    .history-thumb {
        width: 44px;
        height: 44px;
        border-radius: 6px;
        object-fit: cover;
        flex-shrink: 0;
    }
    .played-at { font-size: 0.72rem; color: #6c7781; white-space: nowrap; }

    /* Skeleton */
    .skel {
        background: linear-gradient(90deg,
            rgba(255,255,255,0.04) 25%,
            rgba(255,255,255,0.09) 50%,
            rgba(255,255,255,0.04) 75%);
        background-size: 200% 100%;
        animation: shim 1.4s infinite;
        border-radius: 4px;
    }
    @@keyframes shim {
        0%   { background-position: 200% 0; }
        100% { background-position: -200% 0; }
    }
</style>
}

<div class="page-content page-container" id="page-content">
    <div class="padding">

        <!-- Hero -->
        <div class="page-hero">
            <div class="media bg-media">
                <div class="media-content" style="background-image:url(/bepop/assets/img/b9.jpg)"></div>
            </div>
            <div class="pos-rlt p-4 d-flex align-items-end">
                <div>
                    <h1 class="text-white font-weight-bold mb-1" id="profileUsername">—</h1>
                    <p class="text-muted mb-2" id="profileEmail">—</p>
                    <span class="package-badge package-6" id="profilePackageBadge">Free</span>
                </div>
            </div>
        </div>

        <!-- Giriž yapżlmamżž -->
        <div id="profileNotAuth" style="display:none;" class="text-center py-5">
            <i data-feather="lock" style="width:48px;height:48px;color:#6c7781;"></i>
            <p class="text-muted mt-3">Bu sayfayż görüntülemek iēin giriž yapmanżz gerekiyor.</p>
            <a asp-controller="Home" asp-action="SignIn" class="btn gd-primary text-white btn-rounded mt-2">Giriž Yap</a>
        </div>

        <!-- Żēerik -->
        <div id="profileContent" style="display:none;">
            <div class="row mt-4">

                <!-- Sol: Hesap Bilgileri + Žifre -->
                <div class="col-md-5">

                    <div class="profile-card">
                        <span class="card-label">Hesap Bilgileri</span>
                        <div class="mb-3">
                            <div class="text-muted small mb-1">Kullanżcż Adż</div>
                            <div class="text-white" id="infoUsername">—</div>
                        </div>
                        <div class="mb-3">
                            <div class="text-muted small mb-1">E-posta</div>
                            <div class="text-white" id="infoEmail">—</div>
                        </div>
                        <div>
                            <div class="text-muted small mb-1">Paket</div>
                            <span class="package-badge package-6" id="infoPackage">Free</span>
                        </div>
                    </div>

                    <div class="profile-card">
                        <span class="card-label">Žifre Dešižtir</span>

                        @if (TempData["PasswordError"] != null)
                        {
                            <div class="alert alert-danger py-2 px-3 mb-3" style="border-radius:8px;font-size:.875rem;">
                                @TempData["PasswordError"]
                            </div>
                        }
                        @if (TempData["PasswordSuccess"] != null)
                        {
                            <div class="alert alert-success py-2 px-3 mb-3" style="border-radius:8px;font-size:.875rem;">
                                @TempData["PasswordSuccess"]
                            </div>
                        }

                        <form asp-controller="Home" asp-action="ChangePassword" method="post">
                            @Html.AntiForgeryToken()
                            <div class="mb-3">
                                <div class="text-muted small mb-1">Mevcut Žifre</div>
                                <input type="password" name="CurrentPassword"
                                       class="form-control form-control-dark"
                                       placeholder="••••••••" required />
                            </div>
                            <div class="mb-3">
                                <div class="text-muted small mb-1">Yeni Žifre</div>
                                <input type="password" name="NewPassword"
                                       class="form-control form-control-dark"
                                       placeholder="••••••••" required />
                            </div>
                            <div class="mb-4">
                                <div class="text-muted small mb-1">Yeni Žifre (Tekrar)</div>
                                <input type="password" name="ConfirmNewPassword"
                                       class="form-control form-control-dark"
                                       placeholder="••••••••" required />
                            </div>
                            <button type="submit" class="btn gd-primary text-white btn-block" style="border-radius:8px;">
                                Žifreyi Güncelle
                            </button>
                        </form>
                    </div>

                </div>

                <!-- Saš: Dinleme Geēmiži -->
                <div class="col-md-7">
                    <div class="profile-card" style="min-height:420px;">
                        <span class="card-label">Dinleme Geēmiži</span>

                        <!-- Skeleton -->
                        <div id="historySkeleton">
                            @for (int i = 0; i < 5; i++)
                            {
                                <div class="d-flex align-items-center mb-3">
                                    <div class="skel mr-3" style="width:44px;height:44px;border-radius:6px;flex-shrink:0;"></div>
                                    <div class="flex">
                                        <div class="skel mb-1" style="height:13px;width:55%;"></div>
                                        <div class="skel" style="height:11px;width:35%;"></div>
                                    </div>
                                </div>
                            }
                        </div>

                        <!-- Gerēek liste -->
                        <div id="historyList" style="display:none;"></div>

                        <!-- Bož durum -->
                        <div id="historyEmpty" style="display:none;" class="text-center py-5">
                            <i data-feather="music" style="width:40px;height:40px;color:#6c7781;"></i>
                            <p class="text-muted mt-3 small">Henüz dinleme geēmiži yok.</p>
                        </div>
                    </div>
                </div>

            </div>
        </div>

    </div>
</div>

@section Scripts {
<script>
(function () {
    'use strict';

    function initProfilePage() {
        var token   = localStorage.getItem('jwtToken');
        var content = document.getElementById('profileContent');
        var notAuth = document.getElementById('profileNotAuth');

        if (!content) return; // Bažka sayfada pjaxEnd tetiklendi

        // Sżfżrla
        content.style.display = 'none';
        notAuth.style.display = 'none';
        document.getElementById('historyList').style.display = 'none';
        document.getElementById('historyList').innerHTML = '';
        document.getElementById('historyEmpty').style.display = 'none';
        document.getElementById('historySkeleton').style.display = '';

        if (!token) {
            notAuth.style.display = 'block';
            if (typeof feather !== 'undefined') feather.replace({ width: 16, height: 16 });
            return;
        }

        content.style.display = 'block';

        var headers = { 'Authorization': 'Bearer ' + token };

        function esc(v) {
            return String(v || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
        }

        // Kullanżcż profili
        fetch('/api/Users/profile', { headers: headers })
            .then(function (r) {
                if (r.status === 401) {
                    localStorage.removeItem('jwtToken');
                    content.style.display = 'none';
                    notAuth.style.display = 'block';
                    if (typeof feather !== 'undefined') feather.replace({ width: 16, height: 16 });
                    return null;
                }
                return r.json();
            })
            .then(function (user) {
                if (!user) return;
                var pkgLevel = user.packageLevel || 6;
                var pkgName  = user.packageName  || 'Free';

                document.getElementById('profileUsername').textContent = user.userName || '—';
                document.getElementById('profileEmail').textContent    = user.email    || '—';

                var heroBadge = document.getElementById('profilePackageBadge');
                heroBadge.textContent = pkgName;
                heroBadge.className   = 'package-badge package-' + pkgLevel;

                document.getElementById('infoUsername').textContent = user.userName || '—';
                document.getElementById('infoEmail').textContent    = user.email    || '—';

                var infoBadge = document.getElementById('infoPackage');
                infoBadge.textContent = pkgName;
                infoBadge.className   = 'package-badge package-' + pkgLevel;

                if (typeof feather !== 'undefined') feather.replace({ width: 16, height: 16 });
            })
            .catch(function () {});

        // Dinleme geēmiži
        fetch('/api/Users/history', { headers: headers })
            .then(function (r) { return r.ok ? r.json() : []; })
            .then(function (history) {
                document.getElementById('historySkeleton').style.display = 'none';

                if (!history || history.length === 0) {
                    document.getElementById('historyEmpty').style.display = 'block';
                    if (typeof feather !== 'undefined') feather.replace({ width: 16, height: 16 });
                    return;
                }

                var html = '';
                history.forEach(function (item) {
                    var cover   = esc(item.artistImageUrl || '/bepop/assets/img/c0.jpg');
                    var title   = esc(item.songTitle  || '—');
                    var artist  = esc(item.artistName || '—');
                    var album   = esc(item.albumTitle  || '');
                    var date    = new Date(item.playedAt);
                    var dateStr = date.toLocaleDateString('tr-TR') + ' '
                                + date.toLocaleTimeString('tr-TR', { hour: '2-digit', minute: '2-digit' });

                    html +=
                        '<div class="d-flex align-items-center mb-3">' +
                            '<img class="history-thumb mr-3" src="' + cover + '"' +
                                ' onerror="this.src=\'/bepop/assets/img/c0.jpg\'" alt="' + title + '">' +
                            '<div class="flex" style="min-width:0;">' +
                                '<div class="text-white h-1x" style="font-size:.875rem;font-weight:500;">' + title + '</div>' +
                                '<div class="text-muted small">' + artist + (album ? ' &bull; ' + album : '') + '</div>' +
                            '</div>' +
                            '<div class="played-at ml-3">' + esc(dateStr) + '</div>' +
                        '</div>';
                });

                var listEl = document.getElementById('historyList');
                listEl.innerHTML = html;
                listEl.style.display = 'block';
            })
            .catch(function () {
                document.getElementById('historySkeleton').style.display = 'none';
                document.getElementById('historyEmpty').style.display = 'block';
                if (typeof feather !== 'undefined') feather.replace({ width: 16, height: 16 });
            });
    }

    // Żlk yüklemede ēalżžtżr
    initProfilePage();
    window._pageInitRan = true;

    // PJAX ile her navigasyonda tekrar ēalżžtżr
    window.pageInit = initProfilePage;
})();
</script>
}
